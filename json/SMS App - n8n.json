        "query": "SELECT \n    c.phone, \n    c.first_name, \n    c.last_name, \n    COALESCE(m_last.body, 'No messages') as last_message, \n    COALESCE(m_last.created_at, c.created_at) as last_message_at,\n    (SELECT COUNT(*) FROM messages WHERE contact_id = c.id AND read_at IS NULL AND direction = 'inbound') as unread_count\nFROM contacts c\nLEFT JOIN messages m_last ON m_last.id = (SELECT id FROM messages WHERE contact_id = c.id ORDER BY created_at DESC LIMIT 1)\nORDER BY last_message_at DESC;",
