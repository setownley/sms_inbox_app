    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst authToken = '1708c257076a985d35549a8d1f670ba1';\nconst headers = $input.first().json.headers;\nconst body = $input.first().json.body;\nconst webhookUrl = $input.first().json.webhookUrl;\n\nconst twilioSignature = headers['x-twilio-signature'];\n\nif (!twilioSignature) {\n  return [{ json: { \n    valid: false, \n    reason: 'No X-Twilio-Signature header present - possible direct probe', \n    from: body.From ?? 'unknown',\n    ip: headers['cf-connecting-ip'] ?? 'unknown',\n    userAgent: headers['user-agent'] ?? 'unknown',\n    receivedSignature: 'none',\n    expectedSignature: 'n/a',\n    bodyPreview: Object.entries(body).map(([k,v]) => `${k}: ${v}`).join('\\n'),\n    allHeaders: Object.entries(headers).map(([k,v]) => `${k}: ${v}`).join('\\n')\n  }}];\n}\n\nconst sortedKeys = Object.keys(body).sort();\nlet validationString = webhookUrl;\nfor (const key of sortedKeys) {\n  validationString += key + (body[key] ?? '');\n}\n\nconst expectedSignature = crypto\n  .createHmac('sha1', authToken)\n  .update(validationString, 'utf8')\n  .digest('base64');\n\nif (expectedSignature !== twilioSignature) {\n  return [{ json: { \n    valid: false, \n    reason: 'Signature mismatch - possible spoofed request', \n    from: body.From ?? 'unknown',\n    ip: headers['cf-connecting-ip'] ?? 'unknown',\n    userAgent: headers['user-agent'] ?? 'unknown',\n    receivedSignature: twilioSignature,\n    expectedSignature: expectedSignature,\n    bodyPreview: Object.entries(body).map(([k,v]) => `${k}: ${v}`).join('\\n'),\n    allHeaders: Object.entries(headers).map(([k,v]) => `${k}: ${v}`).join('\\n')\n  }}];\n}\n\nreturn [{ json: { valid: true, ...body } }];"
      },
