      "parameters": {
        "jsCode": "// Validate input + compute scheduling fields.\n// Caller sends:\n//   appointment_id, phone, appointment_start (ISO with offset),\n//   first_name (optional), body (fully-rendered),\n//   status_callback_override (optional, dev-vs-prod routing)\n\nconst body = $input.first().json.body || {};\n\n// --- Required fields ---\nconst required = ['appointment_id', 'phone', 'appointment_start', 'body'];\nconst missing = required.filter(k => !body[k] || String(body[k]).trim() === '');\nif (missing.length > 0) {\n  return [{ json: {\n    valid: false,\n    error: 'missing_required_fields',\n    missing,\n    http_status: 400\n  } }];\n}\n\n// --- Phone format (E.164) ---\nconst phone = String(body.phone).trim();\nif (!/^\\+[1-9]\\d{6,14}$/.test(phone)) {\n  return [{ json: {\n    valid: false,\n    error: 'invalid_phone_format',\n    phone,\n    http_status: 400\n  } }];\n}\n\n// --- Parse appointment_start ---\nconst apptStart = new Date(body.appointment_start);\nif (isNaN(apptStart.getTime())) {\n  return [{ json: {\n    valid: false,\n    error: 'invalid_appointment_start',\n    appointment_start: body.appointment_start,\n    http_status: 400\n  } }];\n}\n\n// --- Reject past appointments ---\nconst now = new Date();\nif (apptStart.getTime() <= now.getTime()) {\n  return [{ json: {\n    valid: false,\n    error: 'appointment_in_past',\n    appointment_start: body.appointment_start,\n    http_status: 400\n  } }];\n}\n\n// --- Compute send time: appointment - 20 minutes ---\nconst sendAt = new Date(apptStart.getTime() - 20 * 60 * 1000);\nconst nowPlus15 = new Date(now.getTime() + 15 * 60 * 1000);\n\n// Twilio requires SendAt >= now + 15min.\n// If sendAt is closer than that, send immediately.\nconst mode = sendAt.getTime() >= nowPlus15.getTime() ? 'scheduled' : 'immediate';\n\n// --- Compute expires_at: appointment + 2 hours ---\nconst expiresAt = new Date(apptStart.getTime() + 2 * 60 * 60 * 1000);\n\n// --- Escape body for SQL string interpolation ---\nconst safeBody = String(body.body).replace(/'/g, \"''\");\nconst safeFirstName = String(body.first_name || '').replace(/'/g, \"''\");\n\nreturn [{ json: {\n  valid: true,\n  mode,\n  appointment_id: String(body.appointment_id),\n  phone,\n  first_name: safeFirstName,\n  body_raw: body.body,\n  body_safe: safeBody,\n  appointment_start_iso: apptStart.toISOString(),\n  send_at_iso: sendAt.toISOString(),\n  expires_at_iso: expiresAt.toISOString(),\n  status_callback_override: body.status_callback_override || null\n} }];\n"
      },
