      "parameters": {
        "jsCode": "// Build a URL-encoded form body for Twilio Messages API.\n// Conditionally include ScheduleType, SendAt, StatusCallback only when set.\n\nconst v = $('Validate').first().json;\n\n// URL-encode each name=value pair manually (no URLSearchParams in task runner).\nconst enc = encodeURIComponent;\nconst pairs = [];\n\npairs.push('MessagingServiceSid=' + enc($env.TWILIO_MESSAGING_SERVICE_SID));\npairs.push('To=' + enc(v.phone));\npairs.push('Body=' + enc(v.body_raw));\n\nif (v.mode === 'scheduled') {\n  pairs.push('ScheduleType=' + enc('fixed'));\n  pairs.push('SendAt=' + enc(v.send_at_iso));\n}\n\nif (v.status_callback_override) {\n  pairs.push('StatusCallback=' + enc(v.status_callback_override));\n}\n\nreturn [{ json: { form_body: pairs.join('&') } }];"
